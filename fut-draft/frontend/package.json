{
  "name": "fut-draft",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "jest --config jest.config.cjs --runInBand",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test:e2e:ui": "playwright test --config playwright.config.ts --ui",
    "test:watch": "jest --config jest.config.cjs --watch",
    "storybook": "storybook dev -p 6006",
    "storybook:ci": "storybook dev -p 6006 --ci --no-open --host 127.0.0.1 --exact-port",
    "build-storybook": "storybook build",
    "test-storybook": "test-storybook --url http://127.0.0.1:6006 --browsers chromium --maxWorkers=1 --skipTags skip-visual --no-cache",
    "test:storybook:visual": "start-server-and-test \"npm run storybook:ci\" http-get://127.0.0.1:6006/index.json \"npm run test-storybook\"",
    "test:storybook:update": "start-server-and-test \"npm run storybook:ci\" http-get://127.0.0.1:6006/index.json \"npm run test-storybook -- -u\""
  },
  "dependencies": {
    "classnames": "^2.5.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/addon-links": "^10.4.0",
    "@storybook/react-vite": "^10.4.0",
    "@storybook/test-runner": "^0.24.4",
    "@types/jest": "^30.0.0",
    "@types/jest-image-snapshot": "^6.4.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "babel-jest": "^30.4.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-image-snapshot": "^6.5.2",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.10",
    "sass": "^1.99.0",
    "start-server-and-test": "^3.0.5",
    "storybook": "^10.4.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
